    "# Learn polars\n",
    "import polars as p1\n",
    "df = p1.DataFrame({\n",
    "    \"name\":[\"aman\",\"suman\",\"Rohit\",\"henry\",\"kamal\"],\n",
    "    \"age\":[23,24,24,21,36],\n",
    "    \"marks\":[90,60,70,80,95],\n",
    "    \"salary\":[10000,20000,30000,40000,50000]\n",
    "})  \n",
    "\n",
    "print(df)"
